# --- Claude (reasoning core) ---
ANTHROPIC_API_KEY=sk-ant-...
# Primary model for the life-safety re-triage decision; fast fallback for the hot loop.
VIGIL_MODEL=claude-opus-4-8
VIGIL_FAST_MODEL=claude-haiku-4-5-20251001

# --- ElevenLabs (outbound nurse call) ---
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
# The charge nurse's phone (E.164, e.g. +14155550123). The number Vigil calls on escalation.
NURSE_PHONE_NUMBER=
# Optional: real voice check-in with the patient before paging (soft signals only).
# Without these, soft signals escalate straight to the nurse (fail-safe).
ELEVENLABS_CHECKIN_AGENT_ID=
PATIENT_KIOSK_NUMBER=

# --- Twilio (direct-call fallback) ---
# Use when the ElevenLabs<->Twilio integration isn't available (e.g. Twilio trial
# accounts). Vigil calls NURSE_PHONE_NUMBER directly and speaks the escalation via
# Twilio TTS. If ELEVENLABS_PHONE_NUMBER_ID is set, ElevenLabs is preferred.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Natural voice for the one-shot TTS fallback call (Amazon Polly neural, not Twilio's
# robotic default). The full OpenAI Realtime bridge (marin) is used when a tunnel is up.
VIGIL_TWILIO_TTS_VOICE=Polly.Joanna-Neural

# --- Conversational voice agent (live patient-status tool) ---
# Shared secret the agent's webhook tool sends as X-Vigil-Token (generate a random one).
VIGIL_AGENT_TOKEN=
# Public base URL where ElevenLabs can reach this server (a named cloudflared/ngrok tunnel).
VIGIL_PUBLIC_URL=
# Calm, professional voice for the agent (default: Sarah).
VIGIL_AGENT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- Data ---
# Abridge synthetic FHIR dataset (jsonl). Defaults to the download location.
VIGIL_DATASET_PATH=/Users/pranavachar/Downloads/synthetic-ambient-fhir-25/synthetic-ambient-fhir-25.jsonl

# --- Perception tuning (see vigil/config.py for full list) ---
VIGIL_FALL_CONFIRM_SECONDS=1.0
VIGIL_MOTIONLESS_SECONDS=540
VIGIL_SCREAM_THRESHOLD=0.4
